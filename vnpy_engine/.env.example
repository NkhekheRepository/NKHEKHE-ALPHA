# VN.PY Trading Engine Configuration

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Trading Mode (paper or live)
TRADING_MODE=paper

# Binance API Keys (leave empty for paper trading)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk Parameters
MAX_POSITION_SIZE=10
MAX_DAILY_LOSS=1000
MAX_DRAWDOWN_PCT=20

# RL Checkpoint Interval (seconds)
RL_CHECKPOINT_INTERVAL=1800
